# Copy this file to .env for local development
# On Railway, set these in the dashboard under Variables

ANTHROPIC_API_KEY=sk-ant-...

# Password students use to access the chatbot (change each year)
CHAT_PASSWORD=gsem2025

# Password for the teacher admin panel
ADMIN_PASSWORD=gsem-admin-2025

# Random secret string for signing session tokens — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Storage paths (leave as-is for Railway)
CHROMA_PATH=/data/chroma
PDFS_PATH=/data/pdfs
